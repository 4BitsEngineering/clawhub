# clawhub — Environment variables
# Copy to .env.local and fill with real values.
# Never commit .env / .env.local — only this example.

# -----------------------------------------------------------------------------
# Database — Supabase Postgres
# -----------------------------------------------------------------------------
# Get from Supabase Dashboard → Project Settings → Database → Connection string
# Use the "Connection pooling" string for app runtime (port 6543).
# Use the "Direct connection" for Prisma migrations (port 5432).
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# Auth.js
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET="REPLACE_ME_RANDOM_32_BYTES"

# Production URL (https). For local dev, defaults to http://localhost:3000
AUTH_URL="http://localhost:3000"

# Trust the host header in production (required behind Vercel/proxies)
AUTH_TRUST_HOST="true"

# -----------------------------------------------------------------------------
# Resend (magic link email provider)
# -----------------------------------------------------------------------------
# Get API key from https://resend.com/api-keys
AUTH_RESEND_KEY="re_REPLACE_ME"

# Sender address. Must be from a domain verified in Resend, or use
# onboarding@resend.dev for dev (only delivers to your verified email).
AUTH_RESEND_FROM="noreply@clawhub.local"

# -----------------------------------------------------------------------------
# Future (v0.5+)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
