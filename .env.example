# clawhub — Environment variables
# Copy to .env.local and fill with real values.
# Never commit .env / .env.local — only this example.

# -----------------------------------------------------------------------------
# Database — Supabase Postgres
# -----------------------------------------------------------------------------
# Get from Supabase Dashboard → Project Settings → Database → Connection string
# Two connection modes:
#   - Transaction pooler (port 6543, pgbouncer) → DATABASE_URL  for app runtime
#   - Session pooler / direct (port 5432)       → DIRECT_URL   for Prisma migrate
#
# For Supabase, both come from the dashboard. Use the project-ref-prefixed user
# (e.g. postgres.pjjixcylawrqimtdzjzy).

DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# -----------------------------------------------------------------------------
# Auth.js (NextAuth v5)
# -----------------------------------------------------------------------------
# Generate with:  openssl rand -base64 32
AUTH_SECRET="REPLACE_ME_RANDOM_32_BYTES"

# Production URL (https). For local dev, defaults to http://localhost:3000
AUTH_URL="http://localhost:3000"

# Trust the host header in production (required behind Vercel/proxies)
AUTH_TRUST_HOST="true"

# -----------------------------------------------------------------------------
# Email provider for magic links
# -----------------------------------------------------------------------------
# Dev: no env vars needed — Auth.js is configured to log the magic link to the
# server stdout instead of sending email. See src/lib/auth.ts.
#
# Prod: swap the provider in src/lib/auth.ts for Resend / SES / SMTP and set the
# corresponding env vars here.

# -----------------------------------------------------------------------------
# Future (v0.5+)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
